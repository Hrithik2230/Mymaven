@Library('cicdlibrary')_

pipeline
{
    agent any
    stages
    {
        stage ('ContDownload')
        {
            steps
            {
                script
                {
                    slpipeline.gitdownload("maven")
                }
            }
        }
        stage ('ContBuild')
        {
            steps
            {
                script
                {
                    slpipeline.newbuild()
                }
            }
        }
     
     }
}
