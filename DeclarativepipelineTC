pipeline
{
  agent any
  stages
  {
    stage('ContinuousDownload')
    {
      steps
      {
         script
         {
            try
            {
               git 'https://github.com/Hrithik2230/Maven.git'
            }
            catch (Exception e1)
            {
              emailext body: 'Jenkins is unable to download the code from Git repository', subject: 'Download failed', to: 'git.admin@gmail.com'
              exit(1)
            }
         }

       }

      }
      stage('ContinuousBuild')
      {
        steps
        {
          script
          {
            try
            {
               sh 'mvn package'
            }
            catch (Exception e2)
            {
               emailext body: 'Jenkins is unable to create an artifact from the downloaded code', subject: 'Build failed', to: 'Middleware.team@gmail.com'
               exit(1)
            }

         }

       }
          
      }
      stage('ContinuousDeployment')
      {
        steps
        {
          script
          {
            try
            {
               sh 'scp /var/lib/jenkins/workspace/DeclarativepipelineTC/webapp/target/webapp.war ubuntu@172.31.34.229:/var/lib/tomcat10/webapps/testapp.war'
            }
            catch (Exception e3)
            {
               emailext body: 'Jenkins is unable to deploy the artifact into tomcat on QA server', subject: 'Deployment failed', to: 'Middleware.team@gmail.com'
               exit(1)
            }

         }

       }
          

      }
      stage('ContinuousTesting')
      {
        steps
        {
          script
          {
            try
            {
               git 'https://github.com/Hrithik2230/Testingcode.git'
               sh 'java -jar /var/lib/jenkins/workspace/DeclarativepipelineTC/testing.jar'
            }
            catch (Exception e4)
            {
               emailext body: 'Selenium scripts are showing a failure status', subject: 'Testing failed', to: 'Testing.team@gmail.com'
               exit(1)
            }

         }

       }
          

      }
      stage('ContinuousDelivery')
      {
        steps
        {
          script
          {
            try
            {
               sh 'scp /var/lib/jenkins/workspace/DeclarativepipelineTC/webapp/target/webapp.war ubuntu@172.31.33.192:/var/lib/tomcat10/webapps/liveapp.war'
            }
            catch (Exception e5)
            {
               emailext body: 'Jenkins is unable to deploy into tomcat on Production servers', subject: 'Delivery failed', to: 'Delivery.team@gmail.com'
               exit(1)
            }

         }

       }
          

      }

   }
} 
